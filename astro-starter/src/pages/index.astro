---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading, Link } from 'accessible-astro-components'
---

<DefaultLayout title="Pink Riot Static Site" useTitleTemplate={false}>
  <section class="my-24">
    <div class="space-content container">
      <Heading level="h1">Pink Riot Static Site</Heading>
      <p class="text-2xl">
        A lightweight accessible site with just enough structure to start writing and shipping quickly.
      </p>
      <div class="flex flex-wrap gap-4">
        <Link href="/about" isButton type="primary" animateOnHover animationType="boop">About</Link>
        <Link href="/contact" isButton type="secondary" animateOnHover animationType="boop">Contact</Link>
      </div>
    </div>
  </section>

  <section class="mb-24">
    <div class="container grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-(--border-color-subtle) p-6">
              <Heading level="h2" size="h5">Edit the homepage</Heading>
              <p class="mt-3">Use this page as your hero, landing page, or simple hub for a small accessible site.</p>
            </div>
      <div class="rounded-xl border border-(--border-color-subtle) p-6">
              <Heading level="h2" size="h5">Shape your content</Heading>
              <p class="mt-3">The preset keeps about and contact pages so you can move quickly without extra demo sections.</p>
            </div>
      <div class="rounded-xl border border-(--border-color-subtle) p-6">
              <Heading level="h2" size="h5">Adjust the theme</Heading>
              <p class="mt-3">Update colors, metadata, and navigation in theme.config.ts to match your brand.</p>
            </div>
    </div>
  </section>
</DefaultLayout>
